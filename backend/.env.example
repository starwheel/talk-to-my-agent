# Akool API — Token-based auth (recommended)
AKOOL_API_HOST=https://openapi.akool.com
AKOOL_API_TOKEN=your_akool_token
AKOOL_AUTH_METHOD=auto

# Akool API — Legacy auth (fallback if token not set)
# AKOOL_CLIENT_ID=your_client_id
# AKOOL_CLIENT_SECRET=your_client_secret

# Akool defaults
AKOOL_AVATAR_ID=your_default_avatar_id
AKOOL_VOICE_ID=
AKOOL_LANGUAGE=en
AKOOL_SESSION_DURATION_MINUTES=10

# Database (Supabase/Postgres)
DB_URL=aws-1-us-east-1.pooler.supabase.com
DB_USER=postgres.bepsiusnuseprvgnizlt
DB_PASSWORD=your_password
DB_NAME=postgres
DB_PORT=5432

# Gemini (Vertex AI)
GEMINI_API_KEY=your_gemini_api_key
